{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "siliconomics/overclaim.schema.json",
  "title": "过度宣称登记簿 schema",
  "type": "object",
  "required": ["claims"],
  "additionalProperties": false,
  "properties": {
    "claims": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "claim_key", "claim_text_zh", "decision_window",
          "window_start", "fixation_rule", "falsify_rule"
        ],
        "properties": {
          "claim_key": { "type": "string", "pattern": "^[a-z][a-z0-9_]+$" },
          "claim_text_zh": { "type": "string", "minLength": 1 },
          "related_metrics": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[a-z][a-z0-9_]*(\\.[a-z0-9_]+)+$" }
          },
          "hardness": { "type": "string", "enum": ["hard","medium","soft","wall"] },
          "decision_window": { "type": "string", "pattern": "^[0-9]+(-[0-9]+)?[qy]$" },
          "window_start": { "type": "string", "format": "date" },
          "fixation_rule": { "type": "string", "minLength": 1 },
          "falsify_rule": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["open","fixation_triggered","falsified","expired","inconclusive"]
          },
          "owner": { "type": "string" },
          "note": { "type": "string" }
        }
      }
    }
  }
}
