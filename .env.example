# ============================================================================
# XAR — Turnkey config. Copy to `.env`. The ONLY required value is the API key.
# ============================================================================

# ---- REQUIRED: LLM provider key (default provider = Anthropic) -------------
ANTHROPIC_API_KEY=sk-ant-...
DEEPSEEK_API_KEY=sk-...

# ---- Optional API token (off by default) -----------------------------------
# When set, mutating /api/* requests (POST/PUT/PATCH/DELETE) must send the same
# value via `X-API-Token` (or `Authorization: Bearer`) — guards /approve, */run,
# /exploration/refresh against accidental triggers. Callers (SPA/scripts) must
# send the header once enabled.
# XAR_API_TOKEN=

# ---- Model routing (default provider = DeepSeek V4; any LiteLLM model works) -
# General tier: extraction / summarization / classification / expert filtering
XAR_MODEL_FAST=deepseek/deepseek-v4-flash
# Reasoning tier: thesis / critique / bull-bear debate / expert synthesis
XAR_MODEL_STRONG=deepseek/deepseek-v4-pro
# Effort for the reasoning tier (low|medium|high|max)
XAR_MODEL_EFFORT=high
# (Alternative: claude-haiku-4-5 / claude-opus-4-8 with ANTHROPIC_API_KEY)

# ---- Claude Max subscription via the Agent SDK (quality tasks, zero token bill) --
# Routes report/debate/synthesis/flagship-thesis to Claude Opus on your Max plan —
# NOT the metered ANTHROPIC_API_KEY. Requires (host-only): `claude` CLI logged into a
# Max account (~/.claude/.credentials.json) + `pip install '.[agentsdk]'`. Auto-detected;
# a host without them (or a docker container) silently falls back to GLM/DeepSeek.
# XAR_ANTHROPIC_MAX_ENABLED=true          # default true; set false to disable entirely
# XAR_ANTHROPIC_MAX_MODEL=claude-opus-4-8 # model for the claude-opus-max spec
# XAR_ANTHROPIC_MAX_EFFORT=high           # low|medium|high|max

# ---- ChatGPT/Codex subscription (codex_cli executor; deep-research candidate) ---
# The `codex-sub` spec runs single-shot completions via `codex exec` on the ChatGPT
# Plus/Pro subscription OAuth (~/.codex/auth.json) — zero per-token bill, a peer of
# claude-opus-max in the STRONG/REASONING chains (pin llm.CODEX_PIN to force it).
# Host-only: needs the `codex` CLI logged in (`codex login`). OFF by default — the ChatGPT
# subscription is meant for interactive Codex use, so headless research use is off-label
# (low-volume, quality tasks only). Arm deliberately:
# XAR_CODEX_ENABLED=true                   # default false; opt-in (ToS-sensitive)
# XAR_CODEX_MODEL=gpt-5.5                   # model id passed to `codex exec -m`
# XAR_CODEX_EFFORT=high                     # model_reasoning_effort for quality tasks

# ---- X (Twitter) data source: metered API, monthly hard cap ------------------
# The Fetchy "twitter" source is OFF by default (enable in Jarvy /ops/fetchy).
# ALL X pulls (fetchy hourly experts + nightly daily sweep + exploration voices)
# share one estimated-spend ledger (api_spend table) with a hard monthly cap —
# exhausted (or unreadable) ledger = pulls skipped until next month (fail-closed).
# XAR_X_MONTHLY_BUDGET_USD=20.0            # <=0 disables the source entirely
# XAR_X_USD_PER_1K_TWEETS=0.15             # twitterapi.io rate-card estimate
# XAR_X_USD_PER_REQUEST=0.0002             # per-request minimum-charge estimate

# ---- Local LLM for the glmworker pin (ollama, zero cost; 2026-07 Phase 3+4) --
# Prepends a LOCAL model to the glmworker extraction pin (kg_extract/expert/triage);
# cloud GLM subscription becomes the automatic fallback (connection refused / timeout /
# empty -> rotate). Needs an ollama server reachable at host.docker.internal:11434
# (override via OLLAMA_API_BASE). The key is a non-empty PLACEHOLDER (ollama does not
# validate) — its presence is the "local configured" switch.
# OLLAMA_API_KEY=ollama
# XAR_GLM_WORKER_LOCAL_FIRST=true           # default false
# XAR_GLM_WORKER_LOCAL_MODEL=qwen3-14b-local # registry id; swap/rollback = edit + recreate
#                                            # (qwen3-14b-local = 2026-07-19 benchmark-race winner)

# ---- Embeddings (CPU, no GPU needed; pluggable) ----------------------------
# fastembed model id. bge-small (384d) = fastest turnkey; BAAI/bge-m3 (1024d) = best quality.
XAR_EMBED_MODEL=BAAI/bge-small-en-v1.5
XAR_EMBED_DIM=384

# ---- Database (docker-compose provides this automatically) -----------------
XAR_DATABASE_URL=postgresql://xar:xar@localhost:5432/xar

# ---- Storage for raw artifacts (local FS by default; s3:// for MinIO/S3) ---
XAR_OBJECT_STORE=file://./data/objects

# ---- SEC EDGAR fair-access identity (required by SEC; any real email) ------
XAR_EDGAR_IDENTITY=xar-research you@example.com

# ---- Data posture: self-use (do not redistribute scraped third-party data) -
XAR_DATA_POSTURE=self_use

# ---- Optional LLM provider key ---------------------------------------------
# OPENAI_API_KEY=

# ---- Optional market-data providers (all skipped if blank) -----------------
# The platform runs with NONE of these; each one lights up more structured data.
#   Finnhub  : fundamentals (margins/ratios), estimates, ratings, insider trades
#   FMP      : full statements, analyst estimates, price targets, daily prices
#   Polygon  : deep daily OHLCV history + vX reference financials
#   Yahoo    : free global prices + fundamentals snapshot (incl. CN A-shares) — no key,
#              just `pip install '.[market]'` (yfinance). Polymarket is public, no key.
# FINNHUB_API_KEY=
# FMP_API_KEY=
# POLYGON_API_KEY=
# TUSHARE_TOKEN=

# ---- Optional social / alternative data ------------------------------------
# X (Twitter): TwitterAPI.io key (preferred) OR official X API v2 bearer token.
# Expert handles + domain search -> social_posts -> expert-agent processing.
# TWITTERAPI_TOKEN=
# X_BEARER_TOKEN=
# X_EXPERT_HANDLES=                 # optional CSV of @handles to follow
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=

# ---- AIFINmarket (万得 Wind) — CN A-share professional source --------------
# Wind AIFINmarket MCP key (https://aifinmarket.wind.com.cn). Pure-Python MCP
# client (no node): A-share valuation + announcements + 资讯 -> expert processing.
# AIFINMARKET_TOKEN=
# AIFINMARKET_BASE_URL=             # optional; defaults to https://mcp.wind.com.cn

# ---- Gangtise 投研 Open API — deep CN sell-side research --------------------
# AccessKey/SecretKey from https://open-platform.gangtise.com (审核后获取). Deep
# fundamentals/valuation/一致预期 -> canonical metrics + 投研文本 (one-pager/投资逻辑/
# 同业对比) -> documents -> triage/KG. CN A-share focused. Blank -> skipped.
# GTS_ACCESS_KEY=
# GTS_SECRET_KEY=
# XAR_ENABLE_GANGTISE=false

# ---- Wind (万得 WindPy): legacy local-terminal CN-A fundamentals -----------
# XAR_ENABLE_WIND=false

# ---- Futu / moomoo OpenAPI (富途) — HK personal retail account --------------
# Broad HK + A-share + US coverage (Chinese names, valuation, 资讯 news, 资金流
# capital flow, 板块/产业链 plates) — the HK/CN breadth FMP/finnhub lack.
# 1) Download & run OpenD (the local gateway) and log in with your Futu account;
#    it listens on 127.0.0.1:11111 and talks to Futu servers for you.
# 2) pip install '.[futu]'  (or: pip install futu-api)
# 3) Arm it:
# XAR_ENABLE_FUTU=true
# In docker, OpenD runs on the HOST, so point the container at it:
# FUTU_OPEND_HOST=host.docker.internal      # or the host LAN IP; default 127.0.0.1
# FUTU_OPEND_PORT=11111

# ---- WeChat Official Accounts (微信公众号) via we-mp-rss --------------------
# Run the service:  docker compose --profile wechat up -d
#   then open http://localhost:8001, scan the WeChat QR to log in, subscribe 公众号.
# Point XAR at it (in-compose hostname is `werss`; standalone use localhost):
# WERSS_BASE_URL=http://werss:8001
# WERSS_API_TOKEN=                # only needed for authed endpoints
# WERSS_FEEDS=                    # optional CSV of feed ids; blank = aggregated /rss
# WERSS_FEED_MAP=                 # optional JSON {"<feed_id>":"<company_id>"}

# ---- WeChat 全网发现 (混合漏斗: 本体种子搜索 → 抓取 → 高产号晋升订阅) --------
# 消费一个自托管搜索服务(we-mp-rss 内置搜索 / tmwgsicp/wechat-download-api 等);XAR 只调
# GET {base}/api/search?q=&days=。反爬留在外部服务。默认关(空 base 或未开 → no-op)。
# 详见 WECHAT_DISCOVERY_PLAN.md;部署见 hardware-solutions/apply-minis-wechat-search.sh。
# 两种后端二选一(或并用):
# (A) 文章级——专用搜索服务(wechat-download-api 等,需部署):
# WECHAT_SEARCH_BASE_URL=http://172.17.0.1:8010   # 绑 docker 网关,勿 0.0.0.0/LAN
# WECHAT_SEARCH_API_TOKEN=                         # 仅 authed 端点需要
# (B) 账号级——复用已在跑的 we-mp-rss(search_Biz 搜全网公众号→自动订阅→现有轮询+triage):
#     需 ① we-mp-rss 已扫码登录(会话有效);② 在 we-mp-rss 后台生成 AK/SK(search/add 端点鉴权)。
# WERSS_AK=                                        # we-mp-rss 访问密钥(Authorization: AK-SK ak:sk)
# WERSS_SK=
# XAR_WECHAT_DISCOVER_ENABLED=true                 # 显式点亮(默认 false;两种后端共用此开关)
# (C) 文章级〔推荐,实测可用〕—— wechat-download-api(curl_cffi 登录,搜号→取文→解析全文):
#     部署容器后扫码登录;XAR 调 searchbiz/articles/article。
# WCDA_BASE_URL=http://host.docker.internal:5000   # 容器内经 host-gateway 达宿主上的 wcda

# ---- Exploration module (前沿探索) — frontier-of-knowledge research ---------
# The third top-level module (peer to the Research Portal + Operations Console).
# Sources are PUBLIC (no key): arXiv preprints + curated journals (Quanta, Physics
# World) + X expert voices (uses TWITTERAPI_TOKEN above). Run:  xar explore
# XAR_ARXIV_ENABLED=true            # arXiv + journal RSS on by default
# XAR_ARXIV_MAX_RESULTS=60          # preprints fetched per domain
# XAR_ARXIV_LOOKBACK_DAYS=21        # preprint recency window

# ---- Optional crawl politeness ---------------------------------------------
XAR_HTTP_USER_AGENT=xar-research/0.1 (+research; contact you@example.com)
XAR_CRAWL_DELAY_SECONDS=2

# ---- Andy module (宏观指标 · siliconomics, vendored src/slx) -----------------
# Zero-key connectors work out of the box: sec_edgar (uses XAR_EDGAR_IDENTITY as
# its User-Agent), epoch_ai, fhfa, lbnl, indeed_hiring_lab, bls (v1), stooq.
# Free-registration keys unlock the rest (all optional):
# FRED_API_KEY=                   # https://fred.stlouisfed.org/docs/api/api_key.html
# BEA_API_KEY=                    # https://apps.bea.gov/api/signup/
# EIA_API_KEY=                    # https://www.eia.gov/opendata/register.php
# EMBER_API_KEY=
# ACLED_API_KEY=
# ACLED_EMAIL=
# TICKETMASTER_API_KEY=
# SLX_SLACK_WEBHOOK=              # overclaim verdict-transition alerts (optional)
# Daily sweep is OPT-IN: add `macro` to XAR_DAILY_ENABLED_SOURCES to include the
# macro connectors + identification + overclaim evaluation in the nightly chain.

# ---- 中文嵌入升级(可选)—— 中英混合语料检索质量 --------------------------
# 默认英文 bge-small(384d,turnkey)。中英混合(中文微信/cninfo + 英文 filings)推荐多语 MiniLM
# (384d,快、含中文,~1h 全库重嵌);最高质量用 e5-large(1024d,但 CPU 上 ~10h):
#   xar reembed --model sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2 --dim 384
# 完成后设置以下两项并重启,使查询侧与库内向量一致(dim 必须与所选模型一致):
# XAR_EMBED_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
# XAR_EMBED_DIM=384

# --- Chathy Telegram channel (optional) -------------------------------------
# BotFather HTTP API token; presence arms the long-poll bot alongside `xar serve`.
BOT_HTTP_API=
BOT_ID=
# Comma-separated Telegram chat ids allowed to talk to the bot (empty = allow all;
# each new chat's id is logged so you can tighten this later).
TELEGRAM_ALLOWED_CHATS=
# XAR_ENABLE_TELEGRAM=false  # explicit off-switch
